{
  "name": "cg-portfolio2026",
  "version": "1.0.0",
  "description": "2026 Portfolio for Craig Gieselman - Product Designer (UX and Design Systems",
  "scripts": {
    "start": "npm run tokens:build && eleventy --serve",
    "build": "npm run tokens:build && eleventy",
    "clean": "rm -rf _site",
    "tokens:build": "node scripts/build-tokens-scss.mjs",
    "test:visual": "playwright test --update-snapshots",
    "test:visual:check": "playwright test",
    "test:visual:report": "playwright show-report tests/report"
  },
  "keywords": [
    "portfolio",
    "11ty",
    "design-systems",
    "product design",
    "ux design",
    "ui design"
  ],
  "author": "Craig Gieselman",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-img": "^5.0.0",
    "@playwright/test": "^1.58.2",
    "js-yaml": "^4.1.1",
    "sass": "^1.97.3"
  }
}
