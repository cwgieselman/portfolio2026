  { tier:'semantic', group:'color · text', name:'--color-text', value:'alias → primary-70', type:'color', desc:'Default body text', alias:true, resolvedColor:'#082E54' },
  // ── SEMANTIC · spacing ──────────────────────────────────────────
  { tier:'semantic', group:'spacing', name:'--spacing-xxs', value:'alias → scale-25', type:'spacing', desc:'4px · micro', alias:true, resolvedPx:4 },
  { tier:'semantic', group:'spacing', name:'--spacing-xs', value:'alias → scale-50', type:'spacing', desc:'8px', alias:true, resolvedPx:8 },
  { tier:'semantic', group:'spacing', name:'--spacing-s', value:'alias → scale-75', type:'spacing', desc:'12px', alias:true, resolvedPx:12 },
  { tier:'semantic', group:'spacing', name:'--spacing-m', value:'alias → scale-100', type:'spacing', desc:'16px · base', alias:true, resolvedPx:16 },
  { tier:'semantic', group:'spacing', name:'--spacing-l', value:'alias → scale-125', type:'spacing', desc:'20px', alias:true, resolvedPx:20 },
  { tier:'semantic', group:'spacing', name:'--spacing-xl', value:'alias → scale-150', type:'spacing', desc:'24px', alias:true, resolvedPx:24 },
  { tier:'semantic', group:'spacing', name:'--spacing-xxl', value:'alias → scale-200', type:'spacing', desc:'32px', alias:true, resolvedPx:32 },
  { tier:'semantic', group:'spacing', name:'--spacing-xxxl', value:'alias → scale-250', type:'spacing', desc:'40px', alias:true, resolvedPx:40 },
  // ── SEMANTIC · radius ───────────────────────────────────────────
  { tier:'semantic', group:'radius', name:'--corner-none', value:'0px', type:'dimension', desc:'No radius', dimPreview:'0' },
  { tier:'semantic', group:'radius', name:'--corner-xxs', value:'alias → scale-25', type:'dimension', desc:'4px', alias:true, resolvedPx:4 },
  { tier:'semantic', group:'radius', name:'--corner-xs', value:'alias → scale-50', type:'dimension', desc:'8px', alias:true, resolvedPx:8 },
  { tier:'semantic', group:'radius', name:'--corner-s', value:'alias → scale-75', type:'dimension', desc:'12px', alias:true, resolvedPx:12 },
  { tier:'semantic', group:'radius', name:'--corner-m', value:'alias → scale-100', type:'dimension', desc:'16px', alias:true, resolvedPx:16 },
  { tier:'semantic', group:'radius', name:'--corner-l', value:'alias → scale-125', type:'dimension', desc:'20px', alias:true, resolvedPx:20 },
  { tier:'semantic', group:'radius', name:'--corner-xl', value:'alias → scale-150', type:'dimension', desc:'24px', alias:true, resolvedPx:24 },
  { tier:'semantic', group:'radius', name:'--corner-xxl', value:'alias → scale-200', type:'dimension', desc:'32px', alias:true, resolvedPx:32 },
