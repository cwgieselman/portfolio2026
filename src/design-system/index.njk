---
layout: layouts/base.njk
title: "Design System"
permalink: "/design-system/"
pageKey: "design-system"
mainClass: "layout--design-system"
---

<main class="layout {{ mainClass }}">
  <div class="ds-hub">

    <header class="ds-hub__header">
      <h1 class="ds-hub__title">Design system</h1>
      <p class="ds-hub__meta">portfolio2026 &middot; CGDC-DS &middot; tokens/tokens.json &rarr; tokenDocs.js &middot; Eleventy data pipeline</p>
    </header>

    <nav class="ds-hub__top-nav" aria-label="Design system sections">
      <button class="ds-hub__top-tab ds-hub__top-tab--active" onclick="dsSetTab('ds-tokens', this)">Tokens</button>
      {# Component gallery tab — deferred. Uncomment when gallery is ready. #}
      {# <button class="ds-hub__top-tab" onclick="dsSetTab('ds-components', this)">Components</button> #}
    </nav>

    <!-- TOKENS PANEL -->
    <section class="ds-panel ds-panel--active" id="ds-tokens" aria-label="Design tokens">
      <div class="ds-tokens__controls">
        <div class="ds-tokens__tiers" id="t-tier-nav"></div>
        <div class="ds-tokens__view-toggle">
          <button class="ds-tokens__view-btn ds-tokens__view-btn--active" id="t-btn-list" onclick="tSetView('list')" aria-label="List view">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <rect x="1" y="2" width="12" height="1.5" rx=".75" fill="currentColor"/>
              <rect x="1" y="6.25" width="12" height="1.5" rx=".75" fill="currentColor"/>
              <rect x="1" y="10.5" width="12" height="1.5" rx=".75" fill="currentColor"/>
            </svg>
          </button>
          <button class="ds-tokens__view-btn" id="t-btn-card" onclick="tSetView('card')" aria-label="Card view">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <rect x="1" y="1" width="5.5" height="5.5" rx="1" fill="currentColor"/>
              <rect x="7.5" y="1" width="5.5" height="5.5" rx="1" fill="currentColor"/>
              <rect x="1" y="7.5" width="5.5" height="5.5" rx="1" fill="currentColor"/>
              <rect x="7.5" y="7.5" width="5.5" height="5.5" rx="1" fill="currentColor"/>
            </svg>
          </button>
        </div>
      </div>
      <div class="ds-tokens__type-bar" id="t-type-bar"></div>
      <div class="ds-tokens__output" id="t-output"></div>
    </section>

    {# COMPONENTS PANEL — deferred. Uncomment when gallery is ready. #}
    {# <section class="ds-panel" id="ds-components" aria-label="Component gallery">
      <div class="ds-comp__filter-bar" id="cg-filter-bar"></div>
      <div class="ds-comp__gallery" id="cg-gallery"></div>
      <div class="ds-comp__detail" id="cg-detail-panel"></div>
    </section> #}

  </div>
</main>

<script id="ds-component-docs-data" type="application/json">
  {{ componentDocs | dump | safe }}
</script>

<script id="ds-token-data" type="application/json">
  {{ tokenDocs | dump | safe }}
</script>

<script>
/* ─────────────────────────────────────────────
   HUB — top-level tab switcher
───────────────────────────────────────────── */
function dsSetTab(targetId, btn) {
  document.querySelectorAll('.ds-hub__top-tab').forEach(b => b.classList.remove('ds-hub__top-tab--active'));
  btn.classList.add('ds-hub__top-tab--active');
  document.querySelectorAll('.ds-panel').forEach(p => p.classList.remove('ds-panel--active'));
  document.getElementById(targetId).classList.add('ds-panel--active');
}

/* ─────────────────────────────────────────────
   TOKEN DATA — sourced from tokens/tokens.json
   via src/_data/tokenDocs.js (Eleventy data transform).
   Do NOT edit manually — update tokens.json and rebuild.
───────────────────────────────────────────── */
const tokens = JSON.parse(document.getElementById('ds-token-data').textContent);

const tierDefs = [
  { key:'primitive', label:'Primitive' },
  { key:'semantic',  label:'Semantic' },
  { key:'component', label:'Component' },
];
let tActiveTier = 'primitive', tActiveType = 'all', tViewMode = 'list';

function tSetView(v) {
  tViewMode = v;
  document.getElementById('t-btn-list').classList.toggle('ds-tokens__view-btn--active', v === 'list');
  document.getElementById('t-btn-card').classList.toggle('ds-tokens__view-btn--active', v === 'card');
  tRender();
}
function tSetTier(t) { tActiveTier = t; tActiveType = 'all'; tRenderTierNav(); tRenderTypeBar(); tRender(); }
function tSetType(t) { tActiveType = t; tRenderTypeBar(); tRender(); }

function tRenderTierNav() {
  document.getElementById('t-tier-nav').innerHTML = tierDefs.map(t =>
    `<button class="ds-tokens__tier-btn${tActiveTier===t.key?' ds-tokens__tier-btn--active':''}" onclick="tSetTier('${t.key}')">${t.label}</button>`
  ).join('');
}
function tRenderTypeBar() {
  const tt = tokens.filter(t => t.tier === tActiveTier);
  const types = [...new Set(tt.map(t => t.type))];
  if (types.length <= 1) { document.getElementById('t-type-bar').innerHTML = ''; return; }
  const btns = [['all','All'], ...types.map(t => [t, t.charAt(0).toUpperCase()+t.slice(1)])];
  document.getElementById('t-type-bar').innerHTML = btns.map(([k,l]) =>
    `<button class="ds-tokens__type-btn${tActiveType===k?' ds-tokens__type-btn--active':''}" onclick="tSetType('${k}')">${l}</button>`
  ).join('');
}

function tSwatchColor(t) {
  if (t.type !== 'color') return null;
  if (!t.alias && t.value && t.value.startsWith('#')) return t.value;
  if (t.alias && t.resolvedColor) return t.resolvedColor;
  return null;
}

function tPreviewHTML(t, forCard) {
  const color = tSwatchColor(t);
  if (t.type === 'color' && color) {
    const border = (color === '#FFFFFF' || color === '#ffffff') ? 'border:0.5px solid #ddddd8;' : '';
    if (forCard) return `<div class="ds-tokens__card-color" style="background:${color};${border}"></div>`;
    return `<div class="ds-tokens__swatch${t.alias?' ds-tokens__swatch--alias':''}" style="background:${color};${border}"></div>`;
  }
  if (t.type === 'color' && t.alias) {
    const chip = `<div class="ds-tokens__swatch ds-tokens__swatch--alias" style="background:#eee;"></div>`;
    if (forCard) return `<div class="ds-tokens__card-preview">${chip}<span class="ds-tokens__alias-badge">alias</span></div>`;
    return `<div class="ds-tokens__preview-alias">${chip}<span class="ds-tokens__alias-badge">alias</span></div>`;
  }
  if (t.type === 'spacing') {
    const px = t.alias ? (t.resolvedPx || 8) : (t.px || 8);
    const capped = Math.min(px, 80);
    const bar = `<div class="ds-tokens__space-wrap"><div class="ds-tokens__space-bar" style="width:${capped}px;"></div><span class="ds-tokens__space-label">${px}px</span></div>`;
    if (forCard) return `<div class="ds-tokens__card-preview ds-tokens__card-preview--left">${bar}${t.alias?`<span class="ds-tokens__alias-badge">alias</span>`:''}</div>`;
    return t.alias ? `<div class="ds-tokens__preview-alias">${bar}<span class="ds-tokens__alias-badge">alias</span></div>` : bar;
  }
  if (t.type === 'typography' && t.fontFamily) {
    if (t.preview === 'fox') {
      const sz = t.previewSize || '11px';
      const fox = `<span class="ds-tokens__preview-fox" style="font-family:${t.fontFamily};font-size:${sz};">The quick brown fox jumps over the lazy dog</span>`;
      if (forCard) return `<div class="ds-tokens__card-preview ds-tokens__card-preview--top">${fox}</div>`;
      return fox;
    }
    if (t.preview === 'aabb') {
      const sz = t.previewSize || '18px';
      const aabb = `<span class="ds-tokens__preview-aabb" style="font-family:${t.fontFamily};font-size:${sz};">AaBbCc 123</span>`;
      if (forCard) return `<div class="ds-tokens__card-preview">${aabb}</div>`;
      return aabb;
    }
  }
  if (t.type === 'dimension' && t.dimPreview) {
    if (forCard) return `<div class="ds-tokens__card-preview"><span class="ds-tokens__preview-dim">${t.dimPreview}</span></div>`;
    return `<span class="ds-tokens__preview-dim">${t.dimPreview}</span>`;
  }
  if (t.alias) {
    const aliasLabel = `<span class="ds-tokens__alias-badge">alias</span>`;
    if (forCard) return `<div class="ds-tokens__card-preview">${aliasLabel}</div>`;
    return `<div class="ds-tokens__preview-alias">${aliasLabel}</div>`;
  }
  if (forCard) return `<div class="ds-tokens__card-preview"><span class="ds-tokens__badge">${t.type}</span></div>`;
  return `<div class="ds-tokens__preview-empty"></div>`;
}

function tRenderList(groups) {
  return Object.entries(groups).map(([group, items]) => `
    <div class="ds-tokens__group">
      <p class="ds-tokens__group-label">${group}</p>
      <table class="ds-tokens__table">
        ${items.map(t => `
          <tr>
            <td class="ds-tokens__td-preview">${tPreviewHTML(t, false)}</td>
            <td class="ds-tokens__td-name"><code>${t.name}</code></td>
            <td class="ds-tokens__td-value"><code>${t.value}</code></td>
            <td class="ds-tokens__td-desc">${t.desc || ''}</td>
            <td class="ds-tokens__td-badge"><span class="ds-tokens__badge">${t.type}</span></td>
          </tr>`).join('')}
      </table>
    </div>`).join('');
}

function tRenderCards(groups) {
  return Object.entries(groups).map(([group, items]) => `
    <div class="ds-tokens__group">
      <p class="ds-tokens__group-label">${group}</p>
      <div class="ds-tokens__card-grid">
        ${items.map(t => `
          <div class="ds-tokens__card">
            ${tPreviewHTML(t, true)}
            <div class="ds-tokens__card-body">
              <p class="ds-tokens__card-name"><code>${t.name}</code></p>
              <p class="ds-tokens__card-value"><code>${t.value}</code></p>
              <p class="ds-tokens__card-desc">${t.desc || ''}</p>
            </div>
            <div class="ds-tokens__card-footer">
              <span class="ds-tokens__badge">${t.type}</span>
              ${t.alias ? `<span class="ds-tokens__alias-badge">alias</span>` : ''}
            </div>
          </div>`).join('')}
      </div>
    </div>`).join('');
}

function tRender() {
  const filtered = tokens.filter(t => t.tier === tActiveTier && (tActiveType === 'all' || t.type === tActiveType));
  const groups = {};
  filtered.forEach(t => { if (!groups[t.group]) groups[t.group] = []; groups[t.group].push(t); });
  document.getElementById('t-output').innerHTML = tViewMode === 'list' ? tRenderList(groups) : tRenderCards(groups);
}

/* ─────────────────────────────────────────────
   COMPONENT DATA — sourced from src/_data/component-docs/*.yml
   Eleventy injects componentDocs as a global at build time.
   JS preview renderers below are the phase-1 approximation.
   Phase 2: replace preview() with actual njk include calls.
───────────────────────────────────────────── */
const componentDocsData = (() => { try { return JSON.parse(document.getElementById('ds-component-docs-data').textContent); } catch(e) { console.warn('componentDocs failed to parse:', e.message); return {}; } })();

const components = [
  {
    id:'mosaic',
    get name() { return componentDocsData['mosaic'].name; },
    get desc() { return componentDocsData['mosaic'].desc; },
    get tags() { return componentDocsData['mosaic'].tags; },
    links:{ figma:'https://figma.com', njk:'/src/_includes/components/mosaic.njk', netlify:'https://cwgport26.netlify.app' },
    thumb: () => `<div class="ds-thumb-mosaic">
      <div class="ds-thumb-cell ds-thumb-cell--white" style="grid-column:1/3;grid-row:1/3;"><span class="ds-thumb-stat">3&times;</span></div>
      <div class="ds-thumb-cell ds-thumb-cell--img" style="grid-column:3/6;"></div>
      <div class="ds-thumb-cell ds-thumb-cell--white" style="grid-column:3/5;grid-row:2/3;"></div>
      <div class="ds-thumb-cell ds-thumb-cell--white" style="grid-column:5/6;grid-row:2/3;"></div>
    </div>`,
    variants:[
      {
        label:'the arrow problem',
        preview: (theme) => {
          const t = theme || 'white';
          return `<div class="mosaic ds-mosaic-preview" style="grid-template-columns:repeat(5,1fr);grid-template-rows:repeat(2,80px);width:100%;max-width:480px;">
            <article class="mosaic-tile mosaic-tile--content mosaic-tile--theme-${t}" style="grid-column:1/3;grid-row:1/3;">
              <div class="mosaic-tile__inner"><span class="mosaic-stat">3&times;</span><span class="mosaic-body">arrow attempts</span></div>
            </article>
            <article class="mosaic-tile mosaic-tile--image" style="grid-column:3/6;grid-row:1/2;background:var(--color-neutral-50);">
              <div class="mosaic-tile__inner" style="align-items:center;justify-content:center;"><span class="mosaic-body" style="color:var(--color-neutral-60);">still no arrow</span></div>
            </article>
            <article class="mosaic-tile mosaic-tile--content mosaic-tile--theme-${t}" style="grid-column:3/5;grid-row:2/3;">
              <div class="mosaic-tile__inner"><span class="mosaic-body">SVG partial: raster</span></div>
            </article>
            <article class="mosaic-tile mosaic-tile--content mosaic-tile--theme-${t}" style="grid-column:5/6;grid-row:2/3;">
              <div class="mosaic-tile__inner"><span class="mosaic-body">::after: nope</span></div>
            </article>
          </div>`;
        },
        yaml:`<span class="yaml-comment"># bento-article--the-arrow-problem.yml</span>
<span class="yaml-comment"># Last updated: a long day in March 2026</span>

<span class="yaml-key">theme</span>: <span class="yaml-str">white</span>
<span class="yaml-key">cols</span>: <span class="yaml-val">5</span>
<span class="yaml-key">rows</span>: <span class="yaml-val">2</span>
<span class="yaml-key">tiles</span>:
  - <span class="yaml-key">id</span>: <span class="yaml-str">content-cell-01</span>
    <span class="yaml-key">type</span>: <span class="yaml-str">stat</span>
    <span class="yaml-key">col</span>: <span class="yaml-val">1</span>
    <span class="yaml-key">colSpan</span>: <span class="yaml-val">2</span>
    <span class="yaml-key">row</span>: <span class="yaml-val">1</span>
    <span class="yaml-key">rowSpan</span>: <span class="yaml-val">2</span>
    <span class="yaml-key">stat</span>: <span class="yaml-str">"3x"</span>
    <span class="yaml-key">label</span>: <span class="yaml-str">"arrow implementation attempts"</span>
    <span class="yaml-key">arrow</span>: <span class="yaml-str">"content-cell-02"</span>
    <span class="yaml-comment">    # arrow: field exists. Arrow does not.</span>
  - <span class="yaml-key">id</span>: <span class="yaml-str">content-cell-02</span>
    <span class="yaml-key">type</span>: <span class="yaml-str">image</span>
    <span class="yaml-key">col</span>: <span class="yaml-val">3</span>
    <span class="yaml-key">colSpan</span>: <span class="yaml-val">3</span>
    <span class="yaml-key">row</span>: <span class="yaml-val">1</span>
    <span class="yaml-key">media</span>:
      <span class="yaml-key">src</span>: <span class="yaml-str">"bento-arrow.njk"</span>
      <span class="yaml-comment">      # deleted. rip.</span>`,
        get contract() { return componentDocsData['mosaic'].contract; },
        get usage() {
          const d = componentDocsData['mosaic'];
          return { ...d.usage, changelog: d.changelog };
        }
      },
      {
        label:'the compile party',
        preview: (theme) => {
          const t = theme || 'primary-dark';
          return `<div class="mosaic ds-mosaic-preview" style="grid-template-columns:repeat(5,1fr);grid-template-rows:repeat(2,80px);width:100%;max-width:480px;">
            <article class="mosaic-tile mosaic-tile--content mosaic-tile--theme-${t}" style="grid-column:1/3;grid-row:1/3;">
              <div class="mosaic-tile__inner"><span class="mosaic-stat">3</span><span class="mosaic-body">case studies queued</span></div>
            </article>
            <article class="mosaic-tile mosaic-tile--content mosaic-tile--theme-${t}" style="grid-column:3/6;grid-row:1/2;">
              <div class="mosaic-tile__inner"><span class="mosaic-lead">BMTx &middot; INFICON IMS &middot; Impact Mgr</span></div>
            </article>
            <article class="mosaic-tile mosaic-tile--content mosaic-tile--theme-${t}" style="grid-column:3/5;grid-row:2/3;">
              <div class="mosaic-tile__inner"><span class="mosaic-body">slot-first contract</span></div>
            </article>
            <article class="mosaic-tile mosaic-tile--content mosaic-tile--theme-${t}" style="grid-column:5/6;grid-row:2/3;">
              <div class="mosaic-tile__inner"><span class="mosaic-body">TODO:src flagged</span></div>
            </article>
          </div>`;
        },
        yaml:`<span class="yaml-comment"># bento-article--compile-party.yml</span>
<span class="yaml-comment"># Status: waiting on Craig to finish</span>
<span class="yaml-comment"># the article component in Figma</span>

<span class="yaml-key">theme</span>: <span class="yaml-str">dark</span>
<span class="yaml-key">cols</span>: <span class="yaml-val">5</span>
<span class="yaml-key">rows</span>: <span class="yaml-val">2</span>
<span class="yaml-key">tiles</span>:
  - <span class="yaml-key">id</span>: <span class="yaml-str">content-cell-01</span>
    <span class="yaml-key">type</span>: <span class="yaml-str">stat</span>
    <span class="yaml-key">col</span>: <span class="yaml-val">1</span>
    <span class="yaml-key">colSpan</span>: <span class="yaml-val">2</span>
    <span class="yaml-key">row</span>: <span class="yaml-val">1</span>
    <span class="yaml-key">rowSpan</span>: <span class="yaml-val">2</span>
    <span class="yaml-key">stat</span>: <span class="yaml-str">"3"</span>
    <span class="yaml-key">label</span>: <span class="yaml-str">"case studies in the compile party queue"</span>`,
        contract: [],
        usage: null
      }
    ]
  },
  {
    id:'figure',
    get name() { return componentDocsData['figure'].name; },
    get desc() { return componentDocsData['figure'].desc; },
    get tags() { return componentDocsData['figure'].tags; },
    links:{ figma:'https://figma.com', njk:'/src/_includes/components/figure.njk', netlify:null },
    thumb: () => `<div class="ds-thumb-figure">
      <div class="ds-thumb-img-placeholder"></div>
      <div class="ds-thumb-caption-bar"></div>
    </div>`,
    variants:[
      {
        label:'the hasAlt sermon',
        preview: () => `<div class="ds-preview-figure">
          <div class="ds-preview-img-block">
            <code class="ds-preview-code-label">data-optimize</code>
            <span class="ds-preview-code-sub">not on this one</span>
          </div>
          <p class="ds-preview-caption-text">hasAlt: false is correct &middot; this is not laziness</p>
        </div>`,
        yaml:`<span class="yaml-comment"># figure--the-hasalt-sermon.yml</span>

<span class="yaml-key">figure</span>:
  <span class="yaml-key">src</span>: <span class="yaml-str">"inficon--screen--anomaly-app.png"</span>
  <span class="yaml-comment">  # real file. real project. $6M in licensing revenue.</span>
  <span class="yaml-key">alt</span>: <span class="yaml-str">""</span>
  <span class="yaml-comment">  # not lazy. intentional.</span>
  <span class="yaml-key">hasAlt</span>: <span class="yaml-bool">false</span>
  <span class="yaml-key">role</span>: <span class="yaml-str">"presentation"</span>
  <span class="yaml-key">caption</span>: <span class="yaml-str">"Impact Manager anomaly detection, v1. First UX hire. One Craig."</span>`,
        get contract() { return componentDocsData['figure'].contract; },
        get usage() {
          const d = componentDocsData['figure'];
          return { ...d.usage, changelog: d.changelog };
        }
      }
    ]
  },
  {
    id:'media',
    get name() { return componentDocsData['media'].name; },
    get desc() { return componentDocsData['media'].desc; },
    get tags() { return componentDocsData['media'].tags; },
    links:{ figma:'https://figma.com', njk:'/src/_includes/components/media.njk', netlify:null },
    thumb: () => `<div class="ds-thumb-media">
      <code class="ds-thumb-media-label">no figure wrapper</code>
    </div>`,
    variants:[
      {
        label:'the FigJam scroll',
        preview: () => `<div class="ds-preview-scroll">
          <div class="ds-preview-scroll-inner">
            <div class="ds-preview-scroll-dot"></div>
            <div class="ds-preview-scroll-dot"></div>
            <div class="ds-preview-scroll-dot"></div>
            <div class="ds-preview-scroll-dot"></div>
            <div class="ds-preview-scroll-dot ds-preview-scroll-dot--label">needs wider crop</div>
          </div>
          <div class="ds-preview-scroll-fade"></div>
          <code class="ds-preview-scroll-hint">3:1+ needed</code>
        </div>`,
        yaml:`<span class="yaml-comment"># article 07 · currently 1048x692</span>
<span class="yaml-comment"># nearly square. for a scrollable cell. ironic.</span>

<span class="yaml-key">media</span>:
  <span class="yaml-key">src</span>: <span class="yaml-str">"inficon--screen--anomaly-app-figjam.png"</span>
  <span class="yaml-key">scrollable</span>: <span class="yaml-bool">true</span>
  <span class="yaml-key">scrollSrc</span>: <span class="yaml-str">"TODO:src"</span>
  <span class="yaml-comment">  # re-export at 2000px+ wide, 3:1+ ratio</span>
  <span class="yaml-comment">  # we built a token page instead tonight</span>
  <span class="yaml-comment">  # no regrets</span>
  <span class="yaml-key">cssClass</span>: <span class="yaml-str">"mosaic-tile__img"</span>`,
        get contract() { return componentDocsData['media'].contract; },
        get usage() {
          const d = componentDocsData['media'];
          return { ...d.usage, changelog: d.changelog };
        }
      }
    ]
  }
];

const allTags = [...new Set(components.flatMap(c => c.tags))];
let cgActiveFilters = [], cgActiveComp = null, cgVariantState = {}, cgActiveTab = {};

function cgToggleFilter(tag) {
  cgActiveFilters = cgActiveFilters.includes(tag) ? cgActiveFilters.filter(t=>t!==tag) : [...cgActiveFilters,tag];
  cgRenderFilterBar(); cgRenderGallery();
}
function cgFilteredComps() {
  return cgActiveFilters.length ? components.filter(c=>cgActiveFilters.every(f=>c.tags.includes(f))) : components;
}
function cgOpenDetail(id) {
  cgActiveComp = id;
  if (!cgVariantState[id]) cgVariantState[id] = 0;
  if (!cgActiveTab[id]) cgActiveTab[id] = 'yaml';
  cgRenderGallery(); cgRenderDetail();
  document.getElementById('cg-detail-panel').classList.add('ds-comp__detail--open');
  setTimeout(() => document.getElementById('cg-detail-panel').scrollIntoView({behavior:'smooth',block:'nearest'}), 50);
}
function cgCloseDetail() {
  cgActiveComp = null;
  document.getElementById('cg-detail-panel').classList.remove('ds-comp__detail--open');
  cgRenderGallery();
}
function cgSetVariant(id, idx) { cgVariantState[id]=idx; cgRenderDetail(); }
function cgSetTab(id, tab) { cgActiveTab[id]=tab; cgRenderDetail(); }

function cgRenderFilterBar() {
  document.getElementById('cg-filter-bar').innerHTML =
    `<button class="ds-comp__filter${!cgActiveFilters.length?' ds-comp__filter--active':''}" onclick="cgActiveFilters=[];cgRenderFilterBar();cgRenderGallery();">All</button>` +
    allTags.map(t=>`<button class="ds-comp__filter${cgActiveFilters.includes(t)?' ds-comp__filter--active':''}" onclick="cgToggleFilter('${t}')">${t}</button>`).join('');
}
function cgRenderGallery() {
  document.getElementById('cg-gallery').innerHTML = cgFilteredComps().map(c=>`
    <div class="ds-comp__thumb${cgActiveComp&&cgActiveComp!==c.id?' ds-comp__thumb--dimmed':''}${cgActiveComp===c.id?' ds-comp__thumb--active':''}"
         onclick="cgOpenDetail('${c.id}')">
      <div class="ds-comp__thumb-preview">${c.thumb()}</div>
      <div class="ds-comp__thumb-body">
        <p class="ds-comp__thumb-name">${c.name}</p>
        <div class="ds-comp__thumb-tags">${c.tags.map(t=>`<span class="ds-comp__thumb-tag">${t}</span>`).join('')}</div>
      </div>
    </div>`).join('');
}
function cgLinkPill(label, href) {
  return href
    ? `<a class="ds-comp__link-pill" href="${href}" target="_blank" rel="noopener">&#8599; ${label}</a>`
    : `<span class="ds-comp__link-pill ds-comp__link-pill--disabled">&#8599; ${label}</span>`;
}
function cgRenderContract(contract) {
  if (!contract||!contract.length) return `<p class="ds-comp__stub">Contract entries live on the canonical variant.</p>`;
  return contract.map(row=>{
    const isReq = row.required !== undefined ? row.required : row.req;
    return `
    <div class="ds-comp__contract-row">
      <code class="ds-comp__contract-field">${row.field}</code>
      <span class="ds-comp__badge">${row.type}</span>
      <span class="ds-comp__badge ds-comp__badge--${isReq?'req':'opt'}">${isReq?'required':'optional'}</span>
      <span class="ds-comp__contract-desc">${row.desc}</span>
    </div>`;
  }).join('');
}
function cgRenderUsage(usage) {
  if (!usage) return `<p class="ds-comp__stub">Usage notes live on the canonical variant.</p>`;
  const do_ = usage.do || [];
  const dont = usage.dont || [];
  const gotchas = usage.gotchas || [];
  const a11y = usage.a11y || [];
  const related = usage.related || [];
  const changelog = usage.changelog || [];
  return `
    <div class="ds-comp__usage-section">
      <p class="ds-comp__usage-label">When to use &middot; when not to use</p>
      <div class="ds-comp__do-dont">
        <div class="ds-comp__do">
          <p class="ds-comp__do-label">Use when</p>
          ${do_.map(d=>`<p>${d}</p>`).join('')}
        </div>
        <div class="ds-comp__dont">
          <p class="ds-comp__dont-label">Don't use when</p>
          ${dont.map(d=>`<p>${d}</p>`).join('')}
        </div>
      </div>
    </div>
    ${gotchas.length ? `
    <div class="ds-comp__usage-section">
      <p class="ds-comp__usage-label">Known gotchas</p>
      ${gotchas.map(g=>`<div class="ds-comp__gotcha"><span class="ds-comp__gotcha-bullet">&#9650;</span><span class="ds-comp__gotcha-text">${g}</span></div>`).join('')}
    </div>` : ''}
    ${a11y.length ? `
    <div class="ds-comp__usage-section">
      <p class="ds-comp__usage-label">Accessibility</p>
      ${a11y.map(r=>`<div class="ds-comp__a11y-row"><code class="ds-comp__a11y-attr">${r.attr}</code><span class="ds-comp__a11y-desc">${r.desc}</span></div>`).join('')}
    </div>` : ''}
    ${related.length ? `
    <div class="ds-comp__usage-section">
      <p class="ds-comp__usage-label">Related components</p>
      <div class="ds-comp__related">
        ${related.map(r=>`<button class="ds-comp__related-chip" onclick="cgOpenDetail('${r}')">${r}</button>`).join('')}
      </div>
    </div>` : ''}
    ${changelog.length ? `
    <div class="ds-comp__usage-section">
      <p class="ds-comp__usage-label">Changelog</p>
      <table class="ds-comp__changelog">
        ${changelog.map(c=>`
          <tr>
            <td class="ds-comp__changelog-ver">${c.ver}</td>
            <td class="ds-comp__changelog-date">${c.date}</td>
            <td class="ds-comp__changelog-note">${c.note}</td>
          </tr>`).join('')}
      </table>
    </div>` : ''}`;
}
function cgRenderDetail() {
  const comp = components.find(c=>c.id===cgActiveComp);
  if (!comp) return;
  const vIdx = cgVariantState[comp.id]||0;
  const variant = comp.variants[vIdx];
  const tab = cgActiveTab[comp.id]||'yaml';
  document.getElementById('cg-detail-panel').innerHTML = `
    <div class="ds-comp__detail-header">
      <div>
        <p class="ds-comp__detail-title">${comp.name}</p>
        <p class="ds-comp__detail-desc">${comp.desc}</p>
      </div>
      <button class="ds-comp__close-btn" onclick="cgCloseDetail()">&#10005; close</button>
    </div>
    <div class="ds-comp__links-bar">
      ${cgLinkPill('Figma',comp.links.figma)}
      <span class="ds-comp__link-sep">&middot;</span>
      ${cgLinkPill('.njk',comp.links.njk)}
      <span class="ds-comp__link-sep">&middot;</span>
      ${cgLinkPill('Netlify',comp.links.netlify)}
    </div>
    ${comp.variants.length>1?`<div class="ds-comp__variant-bar">${comp.variants.map((v,i)=>`<button class="ds-comp__variant-btn${i===vIdx?' ds-comp__variant-btn--active':''}" onclick="cgSetVariant('${comp.id}',${i})">${v.label}</button>`).join('')}</div>`:''}
    <div class="ds-comp__preview">${variant.preview()}</div>
    <div class="ds-comp__tabs">
      <button class="ds-comp__tab${tab==='yaml'?' ds-comp__tab--active':''}" onclick="cgSetTab('${comp.id}','yaml')">YAML instance</button>
      <button class="ds-comp__tab${tab==='contract'?' ds-comp__tab--active':''}" onclick="cgSetTab('${comp.id}','contract')">Data contract</button>
      <button class="ds-comp__tab${tab==='usage'?' ds-comp__tab--active':''}" onclick="cgSetTab('${comp.id}','usage')">Usage</button>
    </div>
    <div class="ds-comp__tab-panel${tab==='yaml'?' ds-comp__tab-panel--active':''}"><pre>${variant.yaml}</pre></div>
    <div class="ds-comp__tab-panel${tab==='contract'?' ds-comp__tab-panel--active':''}">${cgRenderContract(variant.contract)}</div>
    <div class="ds-comp__tab-panel${tab==='usage'?' ds-comp__tab-panel--active':''}">${cgRenderUsage(variant.usage)}</div>
  `;
}

/* ── INIT ──────────────────────────────────── */
tRenderTierNav(); tRenderTypeBar(); tRender();
if (document.getElementById('cg-filter-bar')) { cgRenderFilterBar(); cgRenderGallery(); }
</script>
