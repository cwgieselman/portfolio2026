  // ── COMPONENT · mosaic type ──────────────────────────────────────
  { tier:'component', group:'mosaic · type', name:'--mosaic-type-stat-family', value:'alias → font-family-display', type:'typography', desc:'Tienne · stat figures', fontFamily:'Tienne,serif', preview:'aabb', previewSize:'24px' },
  { tier:'component', group:'mosaic · type', name:'--mosaic-type-stat-size', value:'alias → scale-450', type:'typography', desc:'72px · stat figures', fontFamily:'Tienne,serif', preview:'aabb', previewSize:'20px' },
  { tier:'component', group:'mosaic · type', name:'--mosaic-type-stat-weight', value:'alias → font-weight-bold', type:'typography', desc:'700', fontFamily:'Tienne,serif', preview:'aabb', previewSize:'18px' },
  // ── COMPONENT · content rhythm ──────────────────────────────────
  { tier:'component', group:'content rhythm', name:'--content-rhythm--block', value:'alias → spacing-xxl', type:'spacing', desc:'32px · between content blocks', alias:true, resolvedPx:32 },
  { tier:'component', group:'content rhythm', name:'--content-rhythm--continuation', value:'0px', type:'spacing', desc:'0 · continuation items stack tight', px:0 },
  { tier:'component', group:'content rhythm', name:'--content-rhythm--list-indent', value:'alias → spacing-l', type:'spacing', desc:'20px · list indentation', alias:true, resolvedPx:20 },
];

const colorVals = [
  '#FFFFFF','#F8F8F7','#ECECE9','#DFDFDE','#000000',
  '#E7EDF4','#CFDBE8','#9FB8D1','#87A6C6','#3E71A3','#0E4D8C','#082E54','#061F38','#041526',
  '#FFFAE6','#FFF0B3','#FFE166','#FFD733','#FFCD00','#CCA400','#997B00','#665200','#191400',
];
const tierDefs = [
  { key:'primitive', label:'Primitive' },
  { key:'semantic',  label:'Semantic' },
  { key:'component', label:'Component' },
];
let tActiveTier = 'primitive', tActiveType = 'all', tViewMode = 'list';

function tSetView(v) {
  tViewMode = v;
  document.getElementById('t-btn-list').classList.toggle('ds-tokens__view-btn--active', v === 'list');
  document.getElementById('t-btn-card').classList.toggle('ds-tokens__view-btn--active', v === 'card');
  tRender();
}
function tSetTier(t) { tActiveTier = t; tActiveType = 'all'; tRenderTierNav(); tRenderTypeBar(); tRender(); }
function tSetType(t) { tActiveType = t; tRenderTypeBar(); tRender(); }

function tRenderTierNav() {
  document.getElementById('t-tier-nav').innerHTML = tierDefs.map(t =>
    `<button class="ds-tokens__tier-btn${tActiveTier===t.key?' ds-tokens__tier-btn--active':''}" onclick="tSetTier('${t.key}')">${t.label}</button>`
  ).join('');
}
function tRenderTypeBar() {
  const tt = tokens.filter(t => t.tier === tActiveTier);
  const types = [...new Set(tt.map(t => t.type))];
  if (types.length <= 1) { document.getElementById('t-type-bar').innerHTML = ''; return; }
  const btns = [['all','All'], ...types.map(t => [t, t.charAt(0).toUpperCase()+t.slice(1)])];
  document.getElementById('t-type-bar').innerHTML = btns.map(([k,l]) =>
    `<button class="ds-tokens__type-btn${tActiveType===k?' ds-tokens__type-btn--active':''}" onclick="tSetType('${k}')">${l}</button>`
  ).join('');
}

function tSwatchColor(t) {
  if (t.alias || t.type !== 'color') return null;
  return colorVals.includes(t.value) ? t.value : null;
}

function tPreviewHTML(t, forCard) {
  const color = tSwatchColor(t);
  if (t.type === 'color' && color) {
    const border = color === '#FFFFFF' ? 'border:0.5px solid #ddddd8;' : '';
    if (forCard) return `<div class="ds-tokens__card-color" style="background:${color};${border}"></div>`;
    return `<div class="ds-tokens__swatch" style="background:${color};${border}"></div>`;
  }
  if (t.type === 'color' && t.alias && t.resolvedColor) {
    const chip = `<div class="ds-tokens__swatch ds-tokens__swatch--alias" style="background:${t.resolvedColor};"></div>`;
    if (forCard) return `<div class="ds-tokens__card-preview">${chip}<span class="ds-tokens__alias-badge">alias</span></div>`;
    return `<div class="ds-tokens__preview-alias">${chip}<span class="ds-tokens__alias-badge">alias</span></div>`;
  }
  if (t.type === 'spacing') {
    const px = t.alias ? (t.resolvedPx || 8) : (t.px || 8);
    const capped = Math.min(px, 80);
    const bar = `<div class="ds-tokens__space-wrap"><div class="ds-tokens__space-bar" style="width:${capped}px;"></div><span class="ds-tokens__space-label">${px}px</span></div>`;
    if (forCard) return `<div class="ds-tokens__card-preview ds-tokens__card-preview--left">${bar}${t.alias?`<span class="ds-tokens__alias-badge">alias</span>`:''}</div>`;
    return t.alias ? `<div class="ds-tokens__preview-alias">${bar}<span class="ds-tokens__alias-badge">alias</span></div>` : bar;
  }
  if (t.type === 'typography' && t.fontFamily) {
    if (t.preview === 'fox') {
      const sz = t.previewSize || '11px';
      const fox = `<span class="ds-tokens__preview-fox" style="font-family:${t.fontFamily};font-size:${sz};">The quick brown fox jumps over the lazy dog</span>`;
      if (forCard) return `<div class="ds-tokens__card-preview ds-tokens__card-preview--top">${fox}</div>`;
      return fox;
    }
    if (t.preview === 'aabb') {
      const sz = t.previewSize || '18px';
      const aabb = `<span class="ds-tokens__preview-aabb" style="font-family:${t.fontFamily};font-size:${sz};">AaBbCc 123</span>`;
      if (forCard) return `<div class="ds-tokens__card-preview">${aabb}</div>`;
      return aabb;
    }
  }
  if (t.type === 'dimension' && t.dimPreview) {
    if (forCard) return `<div class="ds-tokens__card-preview"><span class="ds-tokens__preview-dim">${t.dimPreview}</span></div>`;
    return `<span class="ds-tokens__preview-dim">${t.dimPreview}</span>`;
  }
  if (forCard) return `<div class="ds-tokens__card-preview"><span class="ds-tokens__badge">${t.type}</span></div>`;
  return `<div class="ds-tokens__preview-empty"></div>`;
}

function tRenderList(groups) {
  return Object.entries(groups).map(([group, items]) => `
    <div class="ds-tokens__group">
      <p class="ds-tokens__group-label">${group}</p>
      <table class="ds-tokens__table">
        ${items.map(t => `
          <tr>
            <td class="ds-tokens__td-preview">${tPreviewHTML(t, false)}</td>
            <td class="ds-tokens__td-name"><code>${t.name}</code></td>
            <td class="ds-tokens__td-value"><code>${t.value}</code></td>
            <td class="ds-tokens__td-desc">${t.desc}</td>
            <td class="ds-tokens__td-badge"><span class="ds-tokens__badge">${t.type}</span></td>
          </tr>`).join('')}
      </table>
    </div>`).join('');
}

function tRenderCards(groups) {
  return Object.entries(groups).map(([group, items]) => `
    <div class="ds-tokens__group">
      <p class="ds-tokens__group-label">${group}</p>
      <div class="ds-tokens__card-grid">
        ${items.map(t => `
          <div class="ds-tokens__card">
            ${tPreviewHTML(t, true)}
            <div class="ds-tokens__card-body">
              <p class="ds-tokens__card-name"><code>${t.name}</code></p>
              <p class="ds-tokens__card-value"><code>${t.value}</code></p>
              <p class="ds-tokens__card-desc">${t.desc}</p>
            </div>
            <div class="ds-tokens__card-footer">
              <span class="ds-tokens__badge">${t.type}</span>
              ${t.alias ? `<span class="ds-tokens__alias-badge">alias</span>` : ''}
            </div>
          </div>`).join('')}
      </div>
    </div>`).join('');
}

function tRender() {
  const filtered = tokens.filter(t => t.tier === tActiveTier && (tActiveType === 'all' || t.type === tActiveType));
  const groups = {};
  filtered.forEach(t => { if (!groups[t.group]) groups[t.group] = []; groups[t.group].push(t); });
  document.getElementById('t-output').innerHTML = tViewMode === 'list' ? tRenderList(groups) : tRenderCards(groups);
}

