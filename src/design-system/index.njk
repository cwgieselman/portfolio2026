  { tier:'semantic', group:'typography · paragraph', name:'--type-paragraph-family', value:'alias → font-family-plain', type:'typography', desc:'PT Sans', fontFamily:'"PT Sans",sans-serif', preview:'fox' },
  { tier:'semantic', group:'typography · headings', name:'--type-pageTitle-size', value:'alias → scale-350', type:'typography', desc:'56px · h1', fontFamily:'Raleway,sans-serif', preview:'aabb', previewSize:'20px' },
  { tier:'semantic', group:'typography · headings', name:'--type-sectionHeading-size', value:'alias → scale-200', type:'typography', desc:'32px · h2', fontFamily:'Raleway,sans-serif', preview:'aabb', previewSize:'18px' },
  { tier:'semantic', group:'typography · headings', name:'--type-subheading-size', value:'alias → scale-150', type:'typography', desc:'24px · h3', fontFamily:'Raleway,sans-serif', preview:'aabb', previewSize:'16px' },
