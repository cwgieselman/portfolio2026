---
layout: layouts/base.njk
title: "Design System"
permalink: "/design-system/"
pageKey: "design-system"
mainClass: "layout--design-system"
---

<main class="layout {{ mainClass }}">
  <div class="ds-hub">

    <header class="ds-hub__header">
      <h1 class="ds-hub__title">Design system</h1>
      <p class="ds-hub__meta">portfolio2026 &middot; CGDC-DS &middot; tokens/tokens.json &middot; Nunjucks partials</p>
    </header>

    <nav class="ds-hub__top-nav" aria-label="Design system sections">
      <button class="ds-hub__top-tab ds-hub__top-tab--active" onclick="dsSetTab('ds-tokens', this)">Tokens</button>
      {# Component gallery tab — deferred. Uncomment when gallery is ready. #}
      {# <button class="ds-hub__top-tab" onclick="dsSetTab('ds-components', this)">Components</button> #}
    </nav>

    <!-- TOKENS PANEL -->
    <section class="ds-panel ds-panel--active" id="ds-tokens" aria-label="Design tokens">
      <div class="ds-tokens__controls">
        <div class="ds-tokens__tiers" id="t-tier-nav"></div>
        <div class="ds-tokens__view-toggle">
          <button class="ds-tokens__view-btn ds-tokens__view-btn--active" id="t-btn-list" onclick="tSetView('list')" aria-label="List view">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <rect x="1" y="2" width="12" height="1.5" rx=".75" fill="currentColor"/>
              <rect x="1" y="6.25" width="12" height="1.5" rx=".75" fill="currentColor"/>
              <rect x="1" y="10.5" width="12" height="1.5" rx=".75" fill="currentColor"/>
            </svg>
          </button>
          <button class="ds-tokens__view-btn" id="t-btn-card" onclick="tSetView('card')" aria-label="Card view">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <rect x="1" y="1" width="5.5" height="5.5" rx="1" fill="currentColor"/>
              <rect x="7.5" y="1" width="5.5" height="5.5" rx="1" fill="currentColor"/>
              <rect x="1" y="7.5" width="5.5" height="5.5" rx="1" fill="currentColor"/>
              <rect x="7.5" y="7.5" width="5.5" height="5.5" rx="1" fill="currentColor"/>
            </svg>
          </button>
        </div>
      </div>
      <div class="ds-tokens__type-bar" id="t-type-bar"></div>
      <div class="ds-tokens__output" id="t-output"></div>
    </section>

    {# COMPONENTS PANEL — deferred. Uncomment when gallery is ready. #}
    {# <section class="ds-panel" id="ds-components" aria-label="Component gallery">
      <div class="ds-comp__filter-bar" id="cg-filter-bar"></div>
      <div class="ds-comp__gallery" id="cg-gallery"></div>
      <div class="ds-comp__detail" id="cg-detail-panel"></div>
    </section> #}

  </div>
</main>

<script id="ds-component-docs-data" type="application/json">
  {{ componentDocs | dump | safe }}
</script>

<script>
/* ─────────────────────────────────────────────
   HUB — top-level tab switcher
───────────────────────────────────────────── */
function dsSetTab(targetId, btn) {
  document.querySelectorAll('.ds-hub__top-tab').forEach(b => b.classList.remove('ds-hub__top-tab--active'));
  btn.classList.add('ds-hub__top-tab--active');
  document.querySelectorAll('.ds-panel').forEach(p => p.classList.remove('ds-panel--active'));
  document.getElementById(targetId).classList.add('ds-panel--active');
}

/* ─────────────────────────────────────────────
   TOKEN DATA
───────────────────────────────────────────── */
