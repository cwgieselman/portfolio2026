  { tier:'component', group:'mosaic · theme · white', name:'--mosaic-theme-white-bg', value:'alias → neutral-10', type:'color', desc:'White cell background', alias:true, resolvedColor:'#FFFFFF' },
  { tier:'component', group:'mosaic · theme · white', name:'--mosaic-theme-white-color', value:'alias → primary-60', type:'color', desc:'White cell text', alias:true, resolvedColor:'#0E4D8C' },
  { tier:'component', group:'mosaic · theme · white', name:'--mosaic-theme-white-border', value:'alias → neutral-60', type:'color', desc:'White cell border', alias:true, resolvedColor:'#DFDFDE' },
  { tier:'component', group:'mosaic · theme · primary-dark', name:'--mosaic-theme-primary-dark-bg', value:'alias → primary-60', type:'color', desc:'Dark blue cell background', alias:true, resolvedColor:'#0E4D8C' },
  { tier:'component', group:'mosaic · theme · primary-dark', name:'--mosaic-theme-primary-dark-color', value:'alias → primary-10', type:'color', desc:'Dark blue cell text', alias:true, resolvedColor:'#E7EDF4' },
  { tier:'component', group:'mosaic · theme · primary-dark', name:'--mosaic-theme-primary-dark-border', value:'alias → primary-80', type:'color', desc:'Dark blue cell border', alias:true, resolvedColor:'#061F38' },
