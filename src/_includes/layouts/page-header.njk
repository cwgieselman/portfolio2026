{#
  page-header — sticky page-level h1 header

  Scope: one per page, always h1, always sticky position.
  Sibling to .layout__story and .page-header__frosting inside <main>.

  Carries .layout__chapter so it shares identical column tracks,
  padding, and named lines with the scrolling content below.

  Visual treatment (frosted glass) lives in .page-header__frosting —
  a fixed sibling div in the page template (index.njk), not here.
  JS toggles .is-frosted on that element at the scroll threshold.

  Expects (via data.header):
  - eyebrow: string (· separated, split into chips)
  - showEyebrow: boolean
  - headline: string — the page h1
  - subhead: string
  - showSubhead: boolean
#}

{% set h = data.header %}

{% if h %}
<header class="page-header layout__chapter" aria-label="Page header">
  <div class="page-header__inner">
    {% if h.showEyebrow and h.eyebrow %}
    <div class="page-header__eyebrow">
      {% set chips = h.eyebrow.split(' · ') %}
      {% for chip in chips %}
        <span class="page-header__chip">{{ chip }}</span>
      {% endfor %}
    </div>
    {% endif %}
    <h1 class="page-header__headline">{{ h.headline }}</h1>
    {% if h.showSubhead and h.subhead %}
    <p class="page-header__subhead">{{ h.subhead }}</p>
    {% endif %}
  </div>
</header>
{% endif %}
