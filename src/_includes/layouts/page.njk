{# layouts/page.njk #}
{#
  layout__page is always a mosaic beat container.
  mosaic renders directly here — no content-cell wrapper.
  layout__page carries container-type so mosaic container queries fire correctly.
#}
<div class="layout__page">
  {% from "components/mosaic.njk" import mosaic %}
  {{ mosaic(cell.mosaic) }}
</div>
