{# layouts/content-cell.njk — stabilized thin executor #}

{% set wrapper = cell.wrapper %}
{% set isStack = cell.includes and (cell.includes | length) > 1 %}
<div
  class="content-cell{% if isStack %} content-cell--stack{% endif %}"
  data-cell="{{ wrapper }}"
>

  {# ── Bento branch ──────────────────────────────────────────── #}
  {% if cell.bento %}
    {% from "components/bento-grid.njk" import bentoGrid %}
    {{ bentoGrid(cell.bento) }}

  {# ── Standard includes branch ──────────────────────────────── #}
  {% elif cell.includes and (cell.includes | length) %}
    {% for item in cell.includes %}
      {% if item.include %}
        {% if not item.params %}
            <!-- EXECUTOR_ERROR: missing params for {{ item.include }} -->
        {% endif %}
      {% set params = item.params %}

        {# Single include switch (exactly once) #}
        {% if item.include == "components/figure.njk" %}
          {% set figureParams = params %}
          {% set figureWrapper = wrapper %}
          {% include item.include %}

        {% elseif item.include == "components/header.njk" or item.include == "components/content-header.njk" %}
          {% set headerParams = params %}
          {% set headerParamsId = id %}
          {% include "components/content-header.njk" %}

        {% elseif item.include == "components/link-block.njk" %}
          {% set linkBlockParams = params %}
          {% include item.include %}

        {% elseif item.include == "components/richtext.njk" %}
          {% set richtextParams = params %}
          {% include item.include %}

        {% else %}
            <!-- UNKNOWN_INCLUDE: {{ item.include }} on {{ page.url }} -->
        {% endif %}

      {% endif %}
    {% endfor %}
  {% endif %}

</div>
