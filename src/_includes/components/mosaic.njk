{#
  mosaic.njk
  ─────────────────────────────────────────────────────────────────────────────
  Renders a mosaic from compiled YAML data.

  Usage (via layouts/page.njk):
    {% from "components/mosaic.njk" import mosaic %}
    {{ mosaic(cell.mosaic) }}

  YAML shape (compiled by COMPILE_PROMPTS.md §G):
    mosaic:
      id: inficon--im-research
      cols: 5                        # reference only — drives placements SCSS
      rows: 5                        # reference only — drives placements SCSS
      tiles:
        - id: article-01
          type: frame                # frame | bleed | skeleton
          theme: primary-dark        # omit for bleed tiles
          desktop:                   # reference only — drives placements SCSS
            col: "1 / 2"
            row: "1 / 2"
          content: |                 # raw HTML block — rendered via | safe
            <span class="mosaic-stat">1</span>
            <span class="mosaic-body">Week on-site...</span>

        - id: article-03
          type: bleed                # bleed tiles use media: block, not content:
          desktop:                   # reference only — drives placements SCSS
            col: "4 / 6"
            row: "1 / 2"
          media:
            src: "/assets/images/inficon--photo--rocc-main.jpg"
            hasAlt: true
            alt: "Descriptive alt text for assistive technology"
            sizes: "40vw"
            cssClass: "mosaic-tile__img"

        - id: article-04
          type: bleed                # art-directed: two crops, viewport-switched
          artDirection: true         # emits data-mosaic-media="art-directed" on article
          desktop:
            col: "4 / 6"
            row: "1 / 2"
          media:
            src: "/assets/images/photo--landscape.jpg"     # 4-up crop (>= 624px)
            mobileSrc: "/assets/images/photo--square.jpg"  # 2-up crop (< 624px)
            hasAlt: true
            alt: "Descriptive alt text for assistive technology"

  ── Themes ───────────────────────────────────────────────────────────────────
  theme: primary-dark     → --cell-bg: primary/60, --cell-color: primary/10
  theme: primary-light    → --cell-bg: primary/20, --cell-color: primary/60
  theme: secondary-dark   → --cell-bg: secondary/50, --cell-color: secondary/80
  theme: secondary-light  → --cell-bg: secondary/20, --cell-color: secondary/70
  (omit theme for bleed tiles — transparent bg, no border)

  ── Inline type spans (frame tiles only) ─────────────────────────────────────
  Figma style name       → span class           Source
  Mosaic/Stat            → mosaic-stat          Merriweather Bold, 64px/64px (clamp 50px→72px)
  Mosaic/Stat Label      → mosaic-stat-label    Raleway Bold, 20px/20px, 4px tracking, small-caps
  Mosaic/Lead            → mosaic-lead          Raleway Regular, 20px/32px (clamp 19px→24px)
  Mosaic/Lead Italic     → mosaic-lead-italic   Raleway Italic, 20px/32px (clamp 19px→24px)
  Mosaic/Body            → mosaic-body          PT Sans Regular, 16px/24px (clamp 13px→16px)
  Mosaic/Body Bold       → mosaic-body-bold     PT Sans Bold, 16px/24px (clamp 13px→16px)
  Mosaic/Body Italic     → mosaic-body-italic   PT Sans Italic, 16px/24px (clamp 13px→16px)

  Rules: color: inherit always — theme drives color via --cell-color. Never set color on span
  classes. font-style (italic) and font-variant (small-caps) are not tokenizable — CSS is the
  sole source of truth for those properties.

  ── Render paths ─────────────────────────────────────────────────────────────
  type: bleed + media: block → media.njk include (img, alt, optimization pipeline)
  type: frame                → {{ tile.content | safe }} (raw HTML block)

  ── Placement ──────────────────────────────────────────────────────────────────
  All placement lives in placements/_<pageKey>.scss — nothing inline.
  Real tiles: #mosaic--<id> carries grid-template-areas; [data-mosaic-tile="article-NN"] gets grid-area: aNN.
  Skeleton tiles (P00): #mosaic--<id> carries grid-template-columns/rows; [data-mosaic-tile="article-NN"]
    gets grid-column / grid-row (no named areas — skeleton is a sparse positional underlay).
  desktop.col / desktop.row in YAML are reference only — consumed during compile, not by this template.
  z-index: in placements SCSS only.

  NOTE: YAML key `tiles:` maps to HTML `<article>` elements — intentional split.
  The semantic HTML element is `<article>`; the YAML vocabulary is `tiles:`.
  ─────────────────────────────────────────────────────────────────────────────
#}

{% macro mosaic(data) %}
<div class="mosaic" id="mosaic--{{ data.id }}">
  {% for tile in data.tiles %}

  {# Class: type modifier + optional theme. Grid placement lives in placements SCSS. #}
  {% if tile.type == "skeleton" %}

    {# Skeleton tile — bare article, no content, no theme. #}
    {# Grid placement via placements SCSS on #mosaic--<id> — same pattern as real tiles. #}
    {# desktop.col / desktop.row in YAML are reference only — consumed by compile, not template. #}
    <article
      class="mosaic-tile mosaic-tile--skeleton"
      data-mosaic-tile="{{ tile.id }}"
      aria-hidden="true"
    ></article>

  {% elif tile.type == "bleed" and tile.scrollable and tile.media %}

    {#
      Scrollable bleed tile — two sibling <article> elements sharing the same grid-area.
      Both are mosaic-tile--bleed. data-mosaic-media drives show/hide via CSS.
      Desktop: normal bleed tile, shown in 4-up (content-cell ≥ 624px), hidden below.
      Scrollable: 500px tall, overflow: auto both axes, no srcset, shown in 2-up only.
      scrollSrc: is a dedicated image for the scroll context (no srcset processing).
    #}

    {# — Desktop instance — #}
    <article
      class="mosaic-tile mosaic-tile--bleed"
      data-mosaic-tile="{{ tile.id }}"
      data-mosaic-media="desktop"
      aria-hidden="true"
    >
      <div class="mosaic-tile__inner">
        {% set mediaParams = tile.media %}
        {% include "components/media.njk" %}
      </div>
    </article>

    {# — Scrollable instance — #}
    <article
      class="mosaic-tile mosaic-tile--bleed"
      data-mosaic-tile="{{ tile.id }}-scroll"
      data-mosaic-media="scrollable"
      role="region"
      aria-label="{{ tile.media.alt if tile.media.hasAlt else 'Process artifact' }}"
    >
      <div class="mosaic-tile__inner">
        <img
          src="{{ tile.media.scrollSrc }}"
          {% if tile.media.hasAlt %}alt="{{ tile.media.alt }}"{% else %}alt="" role="presentation"{% endif %}
          loading="lazy"
        />
      </div>
    </article>

  {% else %}

    {# Standard tile render path #}
    {% set tileClasses = "mosaic-tile mosaic-tile--" + tile.type %}
    {% if tile.theme %}
      {% set tileClasses = tileClasses + " mosaic-tile--theme-" + tile.theme %}
    {% endif %}
    <article
      class="{{ tileClasses }}"
      data-mosaic-tile="{{ tile.id }}"
      {% if tile.variant %}data-mosaic-variant="{{ tile.variant }}"{% endif %}
      {% if tile.artDirection %}data-mosaic-media="art-directed"{% endif %}
    >
      <div class="mosaic-tile__inner">
        {% if tile.type == "bleed" and tile.artDirection and tile.media %}
          <picture class="mosaic-tile__img">
            <source media="(min-width: 624px)" srcset="{{ tile.media.src }}">
            <source media="(max-width: 623px)" srcset="{{ tile.media.mobileSrc }}">
            <img
              src="{{ tile.media.mobileSrc }}"
              {% if tile.media.hasAlt %}alt="{{ tile.media.alt }}"{% else %}alt="" role="presentation"{% endif %}
              class="mosaic-tile__img"
              loading="lazy"
            />
          </picture>
        {% elif tile.type == "bleed" and tile.media %}
          {% set mediaParams = tile.media %}
          {% include "components/media.njk" %}
        {% else %}
          {{ tile.content | safe }}
        {% endif %}
      </div>

    </article>

  {% endif %}

  {% endfor %}
</div>
{% endmacro %}
