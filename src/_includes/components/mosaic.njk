{#
  mosaic.njk
  ─────────────────────────────────────────────────────────────────────────────
  Renders a mosaic from compiled YAML data.

  Usage (via layouts/page.njk):
    {% from "components/mosaic.njk" import mosaic %}
    {{ mosaic(cell.mosaic) }}

  YAML shape (compiled by COMPILE_PROMPTS.md §G):
    mosaic:
      id: inficon--im-research
      cols: 5                        # reference only — drives placements SCSS
      rows: 5                        # reference only — drives placements SCSS
      tiles:
        - id: article-01
          type: content              # content | image
          theme: primary-dark        # omit for image tiles
          desktop:                   # reference only — drives placements SCSS
            col: "1 / 2"
            row: "1 / 2"
          content: |                 # raw HTML block — rendered via | safe
            <span class="mosaic-stat">1</span>
            <span class="mosaic-body">Week on-site...</span>

        - id: article-03
          type: image                # image tiles use media: block, not content:
          desktop:                   # reference only — drives placements SCSS
            col: "4 / 6"
            row: "1 / 2"
          media:
            src: "/assets/images/inficon--photo--rocc-main.jpg"
            hasAlt: true
            alt: "Descriptive alt text for assistive technology"
            sizes: "40vw"
            cssClass: "mosaic-tile__img"

        - id: article-04
          type: image                # art-directed flavor: two crops, viewport-switched
          artDirection: true         # triggers mosaic-tile--image-directed class + <picture> render
          desktop:
            col: "4 / 6"
            row: "1 / 2"
          media:
            src: "/assets/images/photo--landscape.jpg"     # 5-up crop (>= 1052px)
            mobileSrc: "/assets/images/photo--square.jpg"  # 2-up crop (< 1052px)
            hasAlt: true
            alt: "Descriptive alt text for assistive technology"

  ── Themes ───────────────────────────────────────────────────────────────────
  theme: primary-dark     → --cell-bg: primary/60, --cell-color: primary/10
  theme: primary-light    → --cell-bg: primary/20, --cell-color: primary/60
  theme: secondary-dark   → --cell-bg: secondary/50, --cell-color: secondary/80
  theme: secondary-light  → --cell-bg: secondary/20, --cell-color: secondary/70
  (omit theme for image-only tiles — transparent bg, no border)

  ── Inline type spans ────────────────────────────────────────────────────────
  mosaic-stat           Tienne Bold, clamp 50px→72px
  mosaic-lead           Raleway Regular, clamp 19px→24px
  mosaic-lead-italic    Raleway Italic, clamp 19px→24px
  mosaic-body           PT Sans Regular, clamp 13px→16px
  mosaic-body-bold      PT Sans Bold, clamp 13px→16px

  ── Render paths ─────────────────────────────────────────────────────────────
  type: image + media: block → media.njk include (img, alt, optimization pipeline)
  type: content              → {{ tile.content | safe }} (raw HTML block)

  ── Placement ──────────────────────────────────────────────────────────────────
  All placement lives in placements/_<pageKey>.scss — nothing inline.
  Real tiles: #mosaic--<id> carries grid-template-areas; [data-mosaic-tile="article-NN"] gets grid-area: aNN.
  Skeleton tiles (P00): #mosaic--<id> carries grid-template-columns/rows; [data-mosaic-tile="article-NN"]
    gets grid-column / grid-row (no named areas — skeleton is a sparse positional underlay).
  desktop.col / desktop.row in YAML are reference only — consumed during compile, not by this template.
  z-index: in placements SCSS only.

  NOTE: YAML key `tiles:` maps to HTML `<article>` elements — intentional split.
  The semantic HTML element is `<article>`; the YAML vocabulary is `tiles:`.
  ─────────────────────────────────────────────────────────────────────────────
#}

{% macro mosaic(data) %}
<div class="mosaic" id="mosaic--{{ data.id }}">
  {% for tile in data.tiles %}

  {# Class: type modifier + optional theme. Grid placement lives in placements SCSS. #}
  {% if tile.type == "skeleton" %}

    {# Skeleton tile — bare article, no content, no theme. #}
    {# Grid placement via placements SCSS on #mosaic--<id> — same pattern as real tiles. #}
    {# desktop.col / desktop.row in YAML are reference only — consumed by compile, not template. #}
    <article
      class="mosaic-tile mosaic-tile--skeleton"
      data-mosaic-tile="{{ tile.id }}"
      aria-hidden="true"
    ></article>

  {% elif tile.type == "image" and tile.scrollable and tile.media %}

    {#
      Scrollable image tile — two sibling <article> elements sharing the same grid-area.
      Desktop instance: normal image tile, shown in 4-up (content-cell ≥ 624px), hidden below.
      Scrollable instance: 500px tall, overflow: auto both axes, no srcset, shown in 2-up only.
      scrollSrc: is a dedicated image for the scroll context (no srcset processing).
    #}

    {# — Desktop instance — #}
    <article
      class="mosaic-tile mosaic-tile--image mosaic-tile--image-desktop"
      data-mosaic-tile="{{ tile.id }}"
      aria-hidden="true"
    >
      <div class="mosaic-tile__inner">
        {% set mediaParams = tile.media %}
        {% include "components/media.njk" %}
      </div>
    </article>

    {# — Scrollable instance — #}
    <article
      class="mosaic-tile mosaic-tile--image mosaic-tile--image-scrollable"
      data-mosaic-tile="{{ tile.id }}-scroll"
      role="region"
      aria-label="{{ tile.media.alt if tile.media.hasAlt else 'Process artifact' }}"
    >
      <div class="mosaic-tile__inner">
        <img
          src="{{ tile.media.scrollSrc }}"
          {% if tile.media.hasAlt %}alt="{{ tile.media.alt }}"{% else %}alt="" role="presentation"{% endif %}
          loading="lazy"
        />
      </div>
    </article>

  {% else %}

    {# Standard tile render path #}
    {# image-directed: opt-in art direction — <picture> with <source media> for 2-up vs 5-up crops. #}
    {% set typeClass = tile.type %}
    {% if tile.type == "image" and tile.artDirection %}
      {% set typeClass = "image-directed" %}
    {% endif %}
    {% set tileClasses = "mosaic-tile mosaic-tile--" + typeClass %}
    {% if tile.theme %}
      {% set tileClasses = tileClasses + " mosaic-tile--theme-" + tile.theme %}
    {% endif %}
    <article
      class="{{ tileClasses }}"
      data-mosaic-tile="{{ tile.id }}"
      {% if tile.variant %}data-mosaic-variant="{{ tile.variant }}"{% endif %}
    >
      <div class="mosaic-tile__inner">
        {% if tile.type == "image" and tile.artDirection and tile.media %}
          <picture class="mosaic-tile__img">
            <source media="(min-width: 1052px)" srcset="{{ tile.media.src }}">
            <source media="(max-width: 1051px)" srcset="{{ tile.media.mobileSrc }}">
            <img
              src="{{ tile.media.mobileSrc }}"
              {% if tile.media.hasAlt %}alt="{{ tile.media.alt }}"{% else %}alt="" role="presentation"{% endif %}
              class="mosaic-tile__img"
              loading="lazy"
            />
          </picture>
        {% elif tile.type == "image" and tile.media %}
          {% set mediaParams = tile.media %}
          {% include "components/media.njk" %}
        {% else %}
          {{ tile.content | safe }}
        {% endif %}
      </div>

    </article>

  {% endif %}

  {% endfor %}
</div>
{% endmacro %}
