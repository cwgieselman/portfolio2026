{% set p = figureParams %}

<figure
  class="figure figure--{{ p.type }}"
  data-figure="{{ figureWrapper }}"
>
  <div class="figure__media">
    {% if not p.src or p.src == "TODO:src" or (p.src and p.src.indexOf("FPO") > -1) %}
      <img
        src="https://baconmockup.com/800/500"
        alt=""
        role="presentation"
        data-placeholder="true"
        data-figure-type="{{ p.type }}"
        loading="lazy"
        decoding="async"
      />
    {% elif p.hasAlt %}
      <img
        src="{{ p.src }}"
        alt="{{ p.alt }}"
        data-optimize
        data-figure-type="{{ p.type }}"
        data-sizes="{{ p.sizes if p.sizes else '100vw' }}"
        loading="lazy"
        decoding="async"
      />
    {% else %}
      <img
        src="{{ p.src }}"
        alt=""
        role="presentation"
        data-optimize
        data-figure-type="{{ p.type }}"
        data-sizes="{{ p.sizes if p.sizes else '100vw' }}"
        loading="lazy"
        decoding="async"
      />
    {% endif %}
  </div>

  {% if p.showCaption and p.caption %}
    <figcaption class="figure__caption">{{ p.caption }}</figcaption>
  {% endif %}
</figure>
