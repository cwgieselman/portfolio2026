{#
  content-header — in-flow section/chapter headers (h2, h3 only)

  Renamed from header.njk. h1 is now exclusively handled by
  page-header.njk (the fixed page-level title with frosting).

  Expects (via headerParams):
  - level: "h2" | "h3"
  - variant: "quiet" (optional — reduces visual weight without changing semantic level)
  - headline: string — may contain inline HTML (e.g. <span class="nobr">...</span>)
  - showEyebrow: boolean
  - eyebrow: string
  - showSubhead: boolean
  - subhead: string

  Chapter Semantics Rule:
  - headerParamsId provides derived ID for the first header in a section.
  - YAML must not define heading IDs.
#}

{% set p = headerParams %}
{% set headingId = headerParamsId %}
{% set variantClass = " header__headline--quiet" if p.variant == "quiet" else "" %}

<header class="header">
    {% if p.showEyebrow and p.eyebrow %}
        <p class="header__eyebrow">{{ p.eyebrow }}</p>
    {% endif %}

    {% if p.level == "h2" %}
        <h2 class="header__headline{{ variantClass }}"{% if headingId %} id="{{ headingId }}"{% endif %}>{{ p.headline | safe }}</h2>
    {% elseif p.level == "h3" %}
        <h3 class="header__headline{{ variantClass }}"{% if headingId %} id="{{ headingId }}"{% endif %}>{{ p.headline | safe }}</h3>
    {% else %}
        <!-- CONTENT_HEADER_ERROR: invalid level (h1 not permitted — use page-header.njk) -->
    {% endif %}

    {% if p.showSubhead and p.subhead %}
        <p class="header__subhead">{{ p.subhead }}</p>
    {% endif %}
</header>
