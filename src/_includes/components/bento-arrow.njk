{#
  bento-arrow.njk
  ─────────────────────────────────────────────────────────────────────────────
  Renders an inline SVG arrow indicator on a bento cell.

  The SVG overflows the cell boundary by 20px on all sides (the bleed zone).
  At rest, all arrow stubs sit flush with the cell edge — no protrusion.
  The active arrow is translated 20px outward via CSS, pointing into the gap.

  Usage (inside bento-grid.njk, after .bento-cell__inner):
    {% if cell.arrow %}
      {% set arrowParams = { arrow: cell.arrow, span: cell.desktop.col + "x" + cell.desktop.row } %}
      {% include "components/bento-arrow.njk" %}
    {% endif %}

  YAML params:
    arrow: "top"        → single direction (1×1 cells)
    arrow: "bottom-2"   → direction + index for spanned cells

  Supported SVG sprites (add files to src/assets/svg/ as spans are authored):
    bento-arrow-1x1.svg  — top, right, down, left
    (more to come)

  CSS targeting (in _bento-arrow.scss):
    [data-arrow="top"]    → #bento-article__arrow-top    translateY(-20px)
    [data-arrow="right"]  → #bento-article__arrow-right  translateX(20px)
    [data-arrow="down"]   → #bento-article__arrow-down   translateY(20px)
    [data-arrow="left"]   → #bento-article__arrow-left   translateX(-20px)

  a11y:
    The SVG is aria-hidden — the relationship between cells is communicated
    via aria-details on the cell pointing to the target cell's ID.
    Arrow is purely decorative.
  ─────────────────────────────────────────────────────────────────────────────
#}

{% if cell.arrow %}
<div
  class="bento-cell__arrow"
  data-arrow="{{ cell.arrow }}"
  aria-hidden="true"
>
  {# Inline the SVG so CSS can target internal path IDs #}
  {# 1×1 sprite — four directional stubs #}
  <svg
    id="bento-arrow-1x1"
    width="180"
    height="180"
    viewBox="0 0 180 180"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <g id="bento-article__arrow-top">
      <path class="arrow-stroke" d="M70 40 L90 20 L110 40" />
      <path class="arrow-fill"   d="M90 20 L70 40 H110 Z" />
    </g>
    <g id="bento-article__arrow-right">
      <path class="arrow-stroke" d="M140 70 L160 90 L140 110" />
      <path class="arrow-fill"   d="M160 90 L140 70 V110 Z" />
    </g>
    <g id="bento-article__arrow-down">
      <path class="arrow-stroke" d="M70 140 L90 160 L110 140" />
      <path class="arrow-fill"   d="M90 160 L70 140 H110 Z" />
    </g>
    <g id="bento-article__arrow-left">
      <path class="arrow-stroke" d="M40 70 L20 90 L40 110" />
      <path class="arrow-fill"   d="M20 90 L40 70 V110 Z" />
    </g>
  </svg>
</div>
{% endif %}
