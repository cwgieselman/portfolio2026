{#
  annotation-toggle.njk
  ─────────────────────────────────────────────────────────────────────────────
  Toggle between a raw artifact image and an annotated version.
  Explicit button action — not a spatial blend, a deliberate frame switch.
  
  Usage:
    {% from "components/annotation-toggle.njk" import annotationToggle %}
    
    {{ annotationToggle(
      raw = {
        src: "/assets/images/bmtx--axure-layout.png",
        alt: ""
      },
      annotated = {
        src: "/assets/images/bmtx--axure-inconsistencies.png",
        alt: "Axure layout annotated with 14 visual inconsistencies"
      },
      caption = "The Axure artifacts Craig inherited — 14 distinct visual inconsistencies identified before design system work began.",
      buttonLabel = "Show annotations"
    ) }}

  Params:
    raw.src             — path to clean artifact image
    raw.alt             — alt text (usually "" — caption carries meaning)
    annotated.src       — path to annotated image
    annotated.alt       — descriptive alt text for annotated state
    caption             — optional <figcaption> text
    buttonLabel         — button label in default (raw) state, default "Show annotations"
    buttonLabelActive   — button label in annotated state, default "Hide annotations"
  ─────────────────────────────────────────────────────────────────────────────
#}

{% macro annotationToggle(raw, annotated, caption = "", buttonLabel = "Show annotations", buttonLabelActive = "Hide annotations") %}
<figure class="annotation-toggle" data-annotation-toggle>

  <div class="annotation-toggle__stage">

    <img
      class="annotation-toggle__img annotation-toggle__img--raw"
      src="{{ raw.src }}"
      alt="{{ raw.alt }}"
    />

    <img
      class="annotation-toggle__img annotation-toggle__img--annotated"
      src="{{ annotated.src }}"
      alt="{{ annotated.alt }}"
      aria-hidden="true"
    />

  </div>

  <div class="annotation-toggle__controls">
    <button
      class="annotation-toggle__btn"
      type="button"
      aria-pressed="false"
      data-label-default="{{ buttonLabel }}"
      data-label-active="{{ buttonLabelActive }}"
    >
      <span class="annotation-toggle__btn-icon" aria-hidden="true"></span>
      <span class="annotation-toggle__btn-text">{{ buttonLabel }}</span>
    </button>
  </div>

  {% if caption %}
  <figcaption class="annotation-toggle__caption">{{ caption }}</figcaption>
  {% endif %}

</figure>
{% endmacro %}
